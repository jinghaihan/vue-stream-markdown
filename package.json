{
  "name": "vue-stream-markdown-monorepo",
  "type": "module",
  "version": "0.6.5",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "Streaming markdown output, Useful for text streams like LLM outputs.",
  "author": "jinghaihan",
  "license": "MIT",
  "homepage": "https://github.com/jinghaihan/vue-stream-markdown#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinghaihan/vue-stream-markdown.git"
  },
  "bugs": {
    "url": "https://github.com/jinghaihan/vue-stream-markdown/issues"
  },
  "scripts": {
    "dev": "pnpm playground:dev",
    "build": "pnpm -F vue-stream-markdown build",
    "playground:dev": "pnpm -F playground dev",
    "playground:build": "pnpm -F playground generate",
    "playground:typecheck": "pnpm -F playground typecheck",
    "playground:prepare": "pnpm -F playground prepare",
    "docs:dev": "pnpm -F docs dev",
    "docs:build": "pnpm -F docs build",
    "deps": "taze major -I",
    "lint": "eslint",
    "typecheck": "pnpm -F vue-stream-markdown typecheck && pnpm playground:typecheck",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "release": "bumpp -r",
    "prepare": "simple-git-hooks && pnpm playground:prepare && skills-npm"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:build",
    "unplugin-icons": "catalog:build",
    "vite": "catalog:build",
    "bumpp": "catalog:dev",
    "nano-staged": "catalog:dev",
    "pncat": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "skills-npm": "catalog:dev",
    "taze": "catalog:dev",
    "typescript": "catalog:dev",
    "unocss": "catalog:frontend",
    "vue": "catalog:frontend",
    "@iconify-json/catppuccin": "catalog:icons",
    "@iconify-json/lucide": "catalog:icons",
    "@nuxt/eslint": "catalog:lint",
    "@octohash/eslint-config": "catalog:lint",
    "@unocss/eslint-plugin": "catalog:lint",
    "eslint": "catalog:lint",
    "eslint-plugin-format": "catalog:lint",
    "@vitest/coverage-v8": "catalog:test",
    "@vue/test-utils": "catalog:test",
    "vitest": "catalog:test",
    "@types/node": "catalog:types"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --fix"
  }
}
