{
  "name": "vue-stream-markdown",
  "type": "module",
  "version": "0.6.5",
  "packageManager": "pnpm@10.32.1",
  "description": "Streaming markdown output, Useful for text streams like LLM outputs.",
  "author": "jinghaihan",
  "license": "MIT",
  "homepage": "https://github.com/jinghaihan/vue-stream-markdown#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinghaihan/vue-stream-markdown.git"
  },
  "bugs": {
    "url": "https://github.com/jinghaihan/vue-stream-markdown/issues"
  },
  "keywords": [
    "vue",
    "markdown",
    "stream",
    "mermaid",
    "katex",
    "latex",
    "customizable"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./index.css": "./dist/index.css",
    "./theme.css": "./dist/theme.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "pnpm playground:dev",
    "build": "pnpm markmend:build && tsdown && pnpm build:css",
    "build:css": "tsx scripts/build-css.ts",
    "markmend:build": "pnpm -F markmend build",
    "playground:dev": "pnpm -F playground dev",
    "playground:build": "pnpm -F playground generate",
    "playground:typecheck": "pnpm -F playground typecheck",
    "playground:prepare": "pnpm -F playground prepare",
    "docs:dev": "pnpm -F docs dev",
    "docs:build": "pnpm -F docs build",
    "deps": "taze major -I",
    "lint": "eslint",
    "typecheck": "vue-tsc --noEmit && pnpm playground:typecheck",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "release": "bumpp -r",
    "prepare": "simple-git-hooks && pnpm playground:prepare && skills-npm",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "beautiful-mermaid": ">=0.1.0",
    "katex": ">=0.16.20",
    "mermaid": ">=11",
    "shiki": ">=3.15.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "beautiful-mermaid": {
      "optional": true
    },
    "katex": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  },
  "dependencies": {
    "@floating-ui/dom": "catalog:frontend",
    "@vueuse/core": "catalog:frontend",
    "markmend": "workspace:*"
  },
  "devDependencies": {
    "beautiful-mermaid": "catalog:",
    "katex": "catalog:",
    "mermaid": "catalog:",
    "shiki": "catalog:",
    "@tsdown/css": "catalog:build",
    "@vitejs/plugin-vue": "catalog:build",
    "tsdown": "catalog:build",
    "unplugin-icons": "catalog:build",
    "vite": "catalog:build",
    "bumpp": "catalog:dev",
    "lightningcss": "catalog:dev",
    "nano-staged": "catalog:dev",
    "pncat": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "skills-npm": "catalog:dev",
    "taze": "catalog:dev",
    "tinyglobby": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "unocss": "catalog:frontend",
    "@iconify-json/catppuccin": "catalog:icons",
    "@iconify-json/lucide": "catalog:icons",
    "@antfu/utils": "catalog:inlined",
    "treechop": "catalog:inlined",
    "@nuxt/eslint": "catalog:lint",
    "@octohash/eslint-config": "catalog:lint",
    "@unocss/eslint-plugin": "catalog:lint",
    "eslint": "catalog:lint",
    "eslint-plugin-format": "catalog:lint",
    "vue-tsc": "catalog:lint",
    "@vitest/coverage-v8": "catalog:test",
    "@vue/test-utils": "catalog:test",
    "vitest": "catalog:test",
    "@types/node": "catalog:types"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --fix"
  }
}
