{
  "name": "@stream-markdown/html",
  "type": "module",
  "version": "1.0.0-beta.2",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/jinghaihan/vue-stream-markdown#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinghaihan/vue-stream-markdown.git"
  },
  "bugs": {
    "url": "https://github.com/jinghaihan/vue-stream-markdown/issues"
  },
  "keywords": [
    "stream-markdown",
    "html",
    "sanitize",
    "custom-element"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "parse5": "catalog:parser",
    "sanitize-html": "catalog:parser",
    "@stream-markdown/core": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "catalog:build",
    "@types/sanitize-html": "catalog:types"
  }
