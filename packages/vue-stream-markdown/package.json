{
  "name": "vue-stream-markdown",
  "type": "module",
  "version": "0.6.5",
  "description": "Streaming markdown output, Useful for text streams like LLM outputs.",
  "author": "jinghaihan",
  "license": "MIT",
  "homepage": "https://github.com/jinghaihan/vue-stream-markdown#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinghaihan/vue-stream-markdown.git"
  },
  "bugs": {
    "url": "https://github.com/jinghaihan/vue-stream-markdown/issues"
  },
  "keywords": [
    "vue",
    "markdown",
    "stream",
    "mermaid",
    "katex",
    "latex",
    "customizable"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./index.css": "./dist/index.css"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm -F markmend build && tsdown && pnpm build:css",
    "build:css": "tsx scripts/build-css.ts",
    "typecheck": "vue-tsc --noEmit -p ./tsconfig.json",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "beautiful-mermaid": ">=0.1.0",
    "katex": ">=0.16.20",
    "mermaid": ">=11",
    "shiki": ">=3.15.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "beautiful-mermaid": {
      "optional": true
    },
    "katex": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  },
  "dependencies": {
    "@floating-ui/dom": "catalog:frontend",
    "@vueuse/core": "catalog:frontend",
    "markmend": "workspace:*"
  },
  "devDependencies": {
    "@antfu/utils": "catalog:inlined",
    "treechop": "catalog:inlined",
    "beautiful-mermaid": "^1.1.3",
    "katex": "^0.16.38",
    "mermaid": "^11.13.0",
    "shiki": "^4.0.2"
  },
  "inlinedDependencies": {
    "micromark-util-types": "2.0.2",
    "@types/unist": "3.0.3",
    "@types/mdast": "4.0.4",
    "mdast-util-from-markdown": "2.0.3",
    "@antfu/utils": "9.3.0",
    "treechop": "0.1.2"
  }
}
