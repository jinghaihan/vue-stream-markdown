{
  "typescript.experimental.useTsgo": true,
  "compilerOptions": {
    "target": "esnext",
    "lib": ["es2023", "DOM"],
    "moduleDetection": "force",
    "module": "preserve",
    "moduleResolution": "bundler",
    "paths": {
      "@root/*": ["./*"],
      "@stream-markdown/shared": ["./packages/internal/shared/src/index.ts"],
      "@stream-markdown/code": ["./packages/internal/code/src/index.ts"],
      "@stream-markdown/mermaid": ["./packages/internal/mermaid/src/index.ts"],
      "@stream-markdown/math": ["./packages/internal/math/src/index.ts"],
      "markmend-ast": ["./packages/markmend-ast/src/index.ts"],
      "markmend": ["./packages/markmend/src/index.ts"],
      "@markmend/*": ["./packages/markmend/src/*"],
      "vue-stream-markdown": ["./packages/vue-stream-markdown/src/index.ts"],
      "@vue-stream-markdown/*": ["./packages/vue-stream-markdown/src/*"],
      "@shared/*": ["./playground/app/*"],
      "@shared/components/*": ["./playground/app/components/*"]
    },
    "resolveJsonModule": true,
    "types": [
      "node",
      "vite/client",
      "unplugin-icons/types/vue"
    ],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": [
    "packages/**/*.ts",
    "docs",
    "docs/.**/**/*.ts",
    "docs/.**/**/*.vue",
    "test",
    "shims.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "playground"
  ]
}
